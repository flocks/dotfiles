# edit confs
alias vconf="nvim ~/.config/nvim/init.vim"
alias iconf="nvim ~/.config/i3/config"
alias resource="source ~/.zshrc"

# folder
alias front="cd ~/ledger-vault-front"
alias llw="cd ~/ledger-live-web"
alias lld="cd ~/ledger-live-desktop"
alias driver="cd ~/ledger-vault-hsm-driver"
alias inte="cd ~/vault-integration"
alias dot="cd ~/dotfiles"
alias poker="cd ~/nlhe-range"
alias gate="cd ~/ledger-vault-api"


# git stuff
alias ga="~/bin/git_add_fzf"
alias gs="git status"
alias gm="git commit"

# programs
alias v="nvim"
alias vim="nvim"
alias img="sxiv"
alias nb=newsboat
alias m="neomutt"
alias hdcast='ffcast -s ffmpeg -f x11grab -framerate 60 -show_region 1 -s %s -i %D+%c -c:v libx264rgb -crf 0 -preset ultrafast'
alias tign='tig --no-merges'

# utils
alias bindings="grep bindsym ~/.config/i3/config | sed s/bindsym// | dmenu -l 10"
alias chmox="chmod +x"
alias ls="ls --color"
alias ll="ls -l"
alias q="exit"
alias cfgs="cat ~/dotfiles/configs"
alias c="~/bin/configs"
# useful to pipe, eg cat file.log | copy
alias copy="xclip -selection c"
