# edit confs
alias vconf="nvim ~/.config/nvim/init.vim"
alias iconf="nvim ~/.config/i3/config"
alias resource="source ~/.zshrc"

# folder
alias front="cd ~/ledger-vault-front"
alias llw="cd ~/ledger-live-web"
alias lld="cd ~/ledger-live-desktop"
alias driver="cd ~/ledger-vault-hsm-driver"
alias inte="cd ~/vault-integration"
alias dot="cd ~/dotfiles"
alias gate="cd ~/ledger-vault-api"


# git stuff
alias ga="~/bin/git_add_fzf"
alias gs="git status"
alias gm="git commit"

# programs
alias v="nvim"
alias vim="nvim"
alias nb=newsboat

# utils
alias bindings="grep bindsym ~/.config/i3/config | sed s/bindsym// | less"
alias chmox="chmod +x"
alias ls="ls --color"
alias ll="ls -l"
alias q="exit"
# useful to pipe, eg cat file.log | copy
alias copy="xclip -selection c"
