# launch terminal
super + Return
      $TERMINAL
# launch chrome
super + c
      google-chrome-stable
# ncmpcpp music player
super + shift + p
      $TERMINAL -e ncmpcpp
# htop
super + shift + t
      $TERMINAL -e htop
# opening ranger
super + e
      $TERMINAL -e lf

# opening newboat
super + shift + b
      $TERMINAL -e newsboat

# opening neomutt
super + shift + m
      $TERMINAL -e neomutt

# dmenu for chosing a blockchain address
super + shift + a
    ~/bin/blockchain-address
super + shift + e
    ~/bin/dmenuunicode


# moving window
super + u
    ~/bin/corner
super + t
    ~/bin/corner top_left
super + b
    ~/bin/corner bottom_left
super + n
    ~/bin/corner bottom_right
super + y
    ~/bin/corner top_right

# lock screen
super + w
    ~/bin/lock

# demnu to lock/restart/shutdown/etcc
super + control + r
  ~/bin/computer

super + x
  rofi -show window

# taking screnshot
super + shift + w
    ~/bin/dscreenshot
# dmenu with chrome bookmarks
super + comma
    ~/bin/chrome-bookmarks
# dmenu link handler
super + period
    ~/bin/dmenu-links
# dmenu to copy docker container id
super + shift + d
    ~/bin/dmenu_docker

# increase sound
super + equal
    pulsemixer --change-volume +5
# decrease sound
super + plus
    pulsemixer --change-volume -5
# mute sound
XF86AudioMute
    pulsemixer --toggle-mute
# mpc toggle play/pause
super + s
    mpc toggle

# dmenu to launch app
super + r
  rofi -show run
# record screen
super + shift + r
  ~/bin/record
